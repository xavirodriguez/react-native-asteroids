{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "mainEntryPointFilePath": "<projectFolder>/packages/core/dist/index.d.ts",
  "bundledPackages": [
    // Checked: packages/core/src/ has no re-exports of msgpackr types, so msgpackr is not listed here
  ],
  "compiler": {
    "skipLibCheck": true
  },
  "apiReport": {
    "enabled": true,
    "reportFolder": "<projectFolder>/etc/"
  },
  "docModel": {
    "enabled": true,
    "apiJsonFilePath": "<projectFolder>/temp/<unscopedPackageName>.api.json"
  },
  "dtsRollup": {
    "enabled": true,
    "untrimmedFilePath": "<projectFolder>/dist/asteroids.d.ts"
  },
  "tsdocMetadata": {
    "enabled": true,
    "tsdocMetadataFilePath": "<projectFolder>/etc/tsdoc-metadata.json"
  },
  "messages": {
    "extractorMessageReporting": {
      "ae-wrong-input-file-type": {
        "logLevel": "none"
      },
      "ae-missing-release-tag": {
        "logLevel": "warning"
      }
    },
    "compilerMessageReporting": {
      "default": {
        "logLevel": "warning"
      }
    },
    "tsdocMessageReporting": {
      "default": {
        "logLevel": "warning"
      }
    }
  }
}
