{
  "name": "@tiny-aster/renderer-skia",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "pnpm exec tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "clean:artifacts": "[ -d src ] && find src -type f \\( -name \"*.js\" -o -name \"*.js.map\" \\) -delete || true"
  },
  "dependencies": {
    "@tiny-aster/core": "workspace:*",
    "@shopify/react-native-skia": "2.4.18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
