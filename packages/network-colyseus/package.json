{
  "name": "@tiny-aster/network-colyseus",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "pnpm exec tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "clean:artifacts": "[ -d src ] && find src -type f \\( -name \"*.js\" -o -name \"*.js.map\" \\) -delete || true"
  },
  "dependencies": {
    "@colyseus/sdk": "^0.17.37",
    "@tiny-aster/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
