{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "lib": [
            "ESNext",
            "dom"
        ],
        "strict": true,
        "declaration": true,
        "sourceMap": true,
        "outDir": "./dist", // OutDir configured to "./dist" to stop contamination of src/
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ]
}
