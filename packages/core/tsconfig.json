{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "lib": [
            "ESNext",
            "dom"
        ],
        "strict": true,
        "declaration": true,
        "sourceMap": true,
        "outDir": "./dist", // PHASE 1.1: Ensure outDir is configured to ./dist to stop contamination
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ]
}
