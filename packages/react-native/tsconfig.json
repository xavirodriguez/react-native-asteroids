{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist", // PHASE 1.1: Ensure outDir is configured to ./dist to stop contamination
        "jsx": "react-jsx",
        "composite": false,
        "incremental": false,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
