# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
.turbo/
**/.turbo/

*.log
# Expo
.expo/
dist/
web-build/
expo-env.d.ts
*.swp

# Native
.kotlin/s
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
**/src/**/*.js
**/src/**/*.js.map

# coverage
coverage/

server.log
web_server.log
npm_output.log

# Documentation artifacts
temp/
etc/
docs/api-reference/
study/

# Explicitly stop contamination of .js and .js.map files in src/
**/src/**/*.js
**/src/**/*.js.map

# Turborepo
.turbo/
**/_turbo/

# Guard for TS-compiled artifacts
src/**/*.js
src/**/*.js.map
packages/*/src/**/*.js
packages/*/src/**/*.js.map
server/src/**/*.js
server/src/**/*.js.map
