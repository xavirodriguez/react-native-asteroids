{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "noEmit": false,
    "skipLibCheck": true,
    "checkJs": false,
    "noImplicitAny": false,
    "strict": false,
    "strictPropertyInitialization": false,
    "strictNullChecks": false
  },
  "include": ["src/engine/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/__tests__/**"]
}
