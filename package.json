{
  "name": "asteroides",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:docs": "tsc --noEmit -p tsconfig.doc.json",
    "test": "jest --runInBand",
    "test:watch": "jest --watchAll",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:extract": "npm run typecheck:docs && npx api-extractor run --local",
    "docs:generate": "api-documenter markdown -i temp -o docs/api-reference",
    "docs:build": "npm run docs:extract && npm run docs:generate",
    "quality": "npm run typecheck && npm run lint && npm run docs:build",
    "quality:fix": "npm run lint:fix && npm run quality",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "build:prod": "eas build --profile production --platform all",
    "deploy:preview": "eas update --branch preview --message 'Preview deploy'",
    "deploy:prod": "eas update --branch production --message 'Production deploy'",
    "deploy:dev": "eas update --branch development --message 'Dev deploy'"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@colyseus/sdk": "^0.17.37",
    "@expo/dom-webview": "^0.1.5",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/ngrok": "4.1.0",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.1",
    "@microsoft/api-documenter": "^7.28.9",
    "@microsoft/api-extractor": "^7.56.3",
    "@microsoft/tsdoc": "^0.16.0",
    "@microsoft/tsdoc-config": "^0.18.1",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-navigation/native": "^7.1.6",
    "@shopify/react-native-skia": "^2.5.3",
    "@tailwindcss/postcss": "^4.1.12",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "expo": "~55.0.7",
    "expo-constants": "~55.0.8",
    "expo-dev-client": "~55.0.17",
    "expo-font": "~55.0.4",
    "expo-haptics": "^55.0.9",
    "expo-keep-awake": "^55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.6",
    "expo-splash-screen": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.10",
    "geist": "^1.4.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.542.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "19.2.0",
    "react-day-picker": "^9.9.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.62.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-resizable-panels": "^3.0.5",
    "recharts": "^3.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.1.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.34.0",
    "@types/jest": "^29.5.14",
    "@types/matter-js": "^0.20.2",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.3.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.10",
    "jiti": "^2.6.1",
    "matter-js": "^0.20.0",
    "react-native-worklets": "^0.7.2",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.41.0"
  },
  "private": true
}