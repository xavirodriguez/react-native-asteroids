{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "downlevelIteration": true,
    "paths": {
      "@/*": [
        "./*",
        "./src/*"
      ],
      "@tiny-aster/core": [
        "./packages/core/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
